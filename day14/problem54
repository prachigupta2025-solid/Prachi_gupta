#include <stdio.h>

int main() {
    int n, key, count = 0;

    printf("Enter size of array: ");
    scanf("%d", &n);

    int arr[n];

    // Input elements
    printf("Enter %d elements:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Input element to find frequency
    printf("Enter element to find frequency: ");
    scanf("%d", &key);

    // Count frequency
    for (int i = 0; i < n; i++) {
        if (arr[i] == key) {
            count++;
        }
    }

    // Display result
    if (count > 0)
        printf("Element %d occurs %d times in the array.\n", key, count);
    else
        printf("Element %d does not exist in the array.\n", key);

    return 0;
}
