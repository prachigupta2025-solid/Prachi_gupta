#include <stdio.h>

int main() {
    int rows;

    printf("Enter number of rows: ");
    scanf("%d", &rows);

    for (int i = 1; i <= rows; i++) {
        // Print spaces before numbers
        for (int j = 1; j <= rows - i; j++) {
            printf(" ");
        }
        // Print numbers increasing
        for (int k = 1; k <= i; k++) {
            printf("%d", k);
        }
        // Print numbers decreasing
        for (int k = i - 1; k >= 1; k--) {
            printf("%d", k);
        }
        printf("\n");
    }

    return 0;
}
