#include <stdio.h>
#include <string.h>

struct Employee {
    int id;
    char name[50];
    float salary;
};

int main() {
    struct Employee employees[100];
    int count = 0, choice, i, id;
    float totalSalary = 0;

    do {
        printf("\n===== Salary Management System =====\n");
        printf("1. Add Employee Salary Record\n");
        printf("2. Display All Records\n");
        printf("3. Search by Employee ID\n");
        printf("4. Calculate Total Salary\n");
        printf("5. Calculate Average Salary\n");
        printf("6. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Employee ID: ");
                scanf("%d", &employees[count].id);
                printf("Enter Name: ");
                scanf("%s", employees[count].name);
                printf("Enter Salary: ");
                scanf("%f", &employees[count].salary);
                count++;
                printf("Record added successfully!\n");
                break;

            case 2:
                printf("\n--- All Employee Salary Records ---\n");
                for (i = 0; i < count; i++) {
                    printf("ID: %d | Name: %s | Salary: %.2f\n",
                           employees[i].id, employees[i].name, employees[i].salary);
                }
                break;

            case 3:
                printf("Enter Employee ID to search: ");
                scanf("%d", &id);
                for (i = 0; i < count; i++) {
                    if (employees[i].id == id) {
                        printf("Record Found: ID: %d | Name: %s | Salary: %.2f\n",
                               employees[i].id, employees[i].name, employees[i].salary);
                        break;
                    }
                }
                if (i == count) {
                    printf("No record found with ID %d.\n", id);
                }
                break;

            case 4:
                totalSalary = 0;
                for (i = 0; i < count; i++) {
                    totalSalary += employees[i].salary;
                }
                printf("Total Salary of all employees: %.2f\n", totalSalary);
                break;

            case 5:
                totalSalary = 0;
                for (i = 0; i < count; i++) {
                    totalSalary += employees[i].salary;
                }
                if (count > 0) {
                    printf("Average Salary: %.2f\n", totalSalary / count);
                } else {
                    printf("No records available to calculate average.\n");
                }
                break;

            case 6:
                printf("Exiting Salary Management System. Goodbye!\n");
                break;

            default:
                printf("Invalid choice. Try again.\n");
        }
    } while (choice != 6);

    return 0;
}
