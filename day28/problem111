#include <stdio.h>
#include <string.h>

struct Ticket {
    int id;
    char name[50];
    char event[50];
    int seats;
    int booked;  // 1 = booked, 0 = canceled
};

int main() {
    struct Ticket tickets[100];
    int count = 0, choice, i, id;

    do {
        printf("\n===== Ticket Booking System =====\n");
        printf("1. Book Ticket\n");
        printf("2. Display All Bookings\n");
        printf("3. Search by Booking ID\n");
        printf("4. Cancel Ticket\n");
        printf("5. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Booking ID: ");
                scanf("%d", &tickets[count].id);
                printf("Enter Name: ");
                scanf("%s", tickets[count].name);
                printf("Enter Event Name: ");
                scanf("%s", tickets[count].event);
                printf("Enter Number of Seats: ");
                scanf("%d", &tickets[count].seats);
                tickets[count].booked = 1;
                count++;
                printf("Ticket booked successfully!\n");
                break;

            case 2:
                printf("\n--- All Bookings ---\n");
                for (i = 0; i < count; i++) {
                    printf("ID: %d | Name: %s | Event: %s | Seats: %d | Status: %s\n",
                           tickets[i].id, tickets[i].name, tickets[i].event,
                           tickets[i].seats, tickets[i].booked ? "Booked" : "Canceled");
                }
                break;

            case 3:
                printf("Enter Booking ID to search: ");
                scanf("%d", &id);
                for (i = 0; i < count; i++) {
                    if (tickets[i].id == id) {
                        printf("Found: ID: %d | Name: %s | Event: %s | Seats: %d | Status: %s\n",
                               tickets[i].id, tickets[i].name, tickets[i].event,
                               tickets[i].seats, tickets[i].booked ? "Booked" : "Canceled");
                        break;
                    }
                }
                if (i == count) {
                    printf("No booking found with ID %d.\n", id);
                }
                break;

            case 4:
                printf("Enter Booking ID to cancel: ");
                scanf("%d", &id);
                for (i = 0; i < count; i++) {
                    if (tickets[i].id == id) {
                        if (tickets[i].booked) {
                            tickets[i].booked = 0;
                            printf("Ticket canceled successfully!\n");
                        } else {
                            printf("Ticket was already canceled.\n");
                        }
                        break;
                    }
                }
                if (i == count) {
                    printf("No booking found with ID %d.\n", id);
                }
                break;

            case 5:
                printf("Exiting Ticket Booking System. Goodbye!\n");
                break;

            default:
                printf("Invalid choice. Try again.\n");
        }
    } while (choice != 5);

    return 0;
}
