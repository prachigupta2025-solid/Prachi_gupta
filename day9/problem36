#include <stdio.h>

int main() {
    int n;

    printf("Enter size of square: ");
    scanf("%d", &n);

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            // Print * for first row, last row, first column, last column
            if (i == 1 || i == n || j == 1 || j == n) {
                printf("* ");
            } else {
                printf("  ");  // Print spaces inside
            }
        }
        printf("\n");
    }

    return 0;
}
