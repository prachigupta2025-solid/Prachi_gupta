#include <stdio.h>
#include <string.h>

int main() {
    char str[100], rev[100];
    int i, j, len;

    printf("Enter a string: ");
    scanf("%s", str);  // Reads string without spaces

    len = 0;
    while (str[len] != '\0') {
        len++;
    }

    // Reverse logic
    j = 0;
    for (i = len - 1; i >= 0; i--) {
        rev[j] = str[i];
        j++;
    }
    rev[j] = '\0';  // Null terminate the reversed string

    printf("Reversed string = %s\n", rev);

    return 0;
}
