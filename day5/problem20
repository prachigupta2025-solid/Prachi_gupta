#include <stdio.h>

// Function to check if a number is prime
int isPrime(int n) {
    if (n <= 1) return 0;
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) return 0;
    }
    return 1;
}

int main() {
    long long num;
    int largestPrime = -1;

    printf("Enter a number: ");
    scanf("%lld", &num);

    // Check factors
    for (int i = 2; i <= num; i++) {
        if (num % i == 0 && isPrime(i)) {
            largestPrime = i;
        }
    }

    if (largestPrime != -1) {
        printf("Largest Prime Factor of %lld is %d\n", num, largestPrime);
    } else {
        printf("No prime factors found.\n");
    }

    return 0;
}
